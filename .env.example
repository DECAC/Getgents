# Clé API OpenRouter — requise pour que l'assistant réponde en conversation.
# Créez un compte sur https://openrouter.ai/keys puis copiez ce fichier en .env.local
OPENROUTER_API_KEY=

# Optionnel : URL de l'API (défaut : https://openrouter.ai/api/v1/chat/completions)
# OPENROUTER_API_URL=

# Optionnel : connecteur IDFM PRIM (transports Île-de-France, temps réel).
# Clé gratuite sur https://prim.iledefrance-mobilites.fr — la clé reste côté
# serveur, elle n'est jamais exposée au navigateur.
# PRIM_API_KEY=

# Optionnel : connecteur Powens — agrégation bancaire en MODE SANDBOX
# (console Powens : https://console.powens.com). Secrets côté serveur
# uniquement. POWENS_USER_TOKEN (recommandé) : jeton utilisateur permanent
# obtenu via POST https://{domain}.biapi.pro/2.0/auth/init — sinon un
# utilisateur sandbox est créé automatiquement (perdu à chaque redéploiement).
# POWENS_DOMAIN=
# POWENS_CLIENT_ID=
# POWENS_CLIENT_SECRET=
# POWENS_USER_TOKEN=

# Optionnel : clés des connecteurs « API REST » configurés dans le builder.
# Quand la clé d'un connecteur est saisie sous la forme env:NOM_DE_VARIABLE,
# elle est lue ici côté serveur (jamais exposée au navigateur). Exemple pour
# un connecteur SerpApi (Google Flights) dont la clé est « env:SERPAPI_KEY » :
# SERPAPI_KEY=

# Persistance des gents publiés (Supabase). Sans ces variables, l'app reste
# en mode maquette : localStorage du navigateur uniquement, rien de partagé.
# 1. Créez un projet sur https://supabase.com/dashboard
# 2. Exécutez supabase/migrations/001_published_gents.sql dans SQL Editor
# 3. Renseignez ici l'URL du projet (Settings → API) et la clé service_role
#    (secrète — côté serveur uniquement, jamais exposée au navigateur).
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# Note environnement Claude Code (remote/web) uniquement : le fetch de Node ne
# lit pas HTTPS_PROXY par défaut — ajoutez NODE_USE_ENV_PROXY=1 aux variables
# d'environnement de l'environnement claude.ai/code (pas dans ce fichier, il
# est chargé trop tard). Inutile en local sur votre machine.

# Optionnel : routines planifiées (veille en tâche de fond). Le endpoint
# /api/routines/run exécute les routines dues. En production sur Vercel,
# vercel.json déclenche un GET horaire ; CRON_SECRET protège l'accès
# (Vercel envoie automatiquement Authorization: Bearer $CRON_SECRET).
# CRON_SECRET=

# Optionnel : diffusion WhatsApp des notes de veille. Compte WhatsApp Business
# (Meta) requis : token permanent et ID du numéro expéditeur. Le destinataire
# doit avoir donné son consentement (opt-in), et hors fenêtre de 24 h seuls les
# messages « template » approuvés passent.
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# NEXT_PUBLIC_APP_URL=https://votre-app.vercel.app
